<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="robot_gripper" params="prefix parent">

        <joint name="gripper_1_link_joint" type="prismatic">
        <parent link="${parent}"/>
        <child link="gripper_1_link"/>
        <origin xyz="0 -0.36 -0.24" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.02" upper="0.25" effort="100" velocity="1.0"/>
        </joint>

        <link name="gripper_1_link">
        <collision name="gripper_1_collision">
            <origin xyz="0 0 0" rpy="1.57080 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cube.008.dae" scale="0.20000 0.04000 0.20000"/>
            </geometry>
        </collision>
        <visual name="gripper_1">
            <origin xyz="0 0 0" rpy="1.57080 0 0"/>
            <geometry>
            <box size="0.40000 0.08000 0.40000"/>
            </geometry>
            <material name="gripper_red">
                <color rgba="0.85 0.10 0.10 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.00000"/>
            <inertia ixx="0.01387" ixy="0.00000" ixz="0.00000"
                    iyy="0.02667" iyz="0.00000" izz="0.01387"/>
        </inertial>
        </link>

        <joint name="gripper_2_link_joint" type="prismatic">
        <parent link="${parent}"/>
        <child link="gripper_2_link"/>
        <origin xyz="0 0.36 -0.24" rpy="1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.02" upper="0.25" effort="100" velocity="1.0"/>
        </joint>

        <link name="gripper_2_link">
        <collision name="gripper_2_collision">
            <origin xyz="0 0 0" rpy="-1.57080 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cube.009.dae" scale="0.20000 0.04000 0.20000"/>
            </geometry>
        </collision>
        <visual name="gripper_2">
            <origin xyz="0 0 0" rpy="-1.57080 0 0"/>
            <geometry>
            <box size="0.40000 0.08000 0.40000"/>
            </geometry>
            <material name="gripper_red">
                <color rgba="0.85 0.10 0.10 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.00000"/>
            <inertia ixx="0.01387" ixy="0.00000" ixz="0.00000"
                    iyy="0.02667" iyz="0.00000" izz="0.01387"/>
        </inertial>
        </link>

    </xacro:macro>

</robot>