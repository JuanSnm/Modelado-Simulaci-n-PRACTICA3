<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="scara_arm" params="prefix parent">

        <joint name="base_gripper_link_joint" type="fixed">
        <parent link="${parent}"/>
        <child link="base_gripper_link"/>
        <origin xyz="0.51563 -0.00006 0.72658" rpy="0 0 0"/>
        </joint>

        <link name="base_gripper_link">
        <collision name="base_gripper_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.dae" scale="0.70000 0.75000 0.07647"/>
            </geometry>
        </collision>
        <visual name="base_gripper">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.dae" scale="0.70000 0.75000 0.07647"/>
            </geometry>
            <material name="arm_grey">
            <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 -0.17512" rpy="0 0 0"/>
            <mass value="20.00000"/>
            <inertia ixx="3.73641" ixy="0" ixz="0" iyy="3.48927" iyz="0" izz="3.61756"/>
        </inertial>
        </link>

        <joint name="arm_1_link_joint" type="revolute">
        <parent link="base_gripper_link"/>
        <child link="arm_1_link"/>
        <origin xyz="0 0 0.74424" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="50" velocity="2"/>
        </joint>

        <link name="arm_1_link">
        <collision name="arm_1_collision">
            <origin xyz="0.72000 0.00000 0.01000" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.002.dae" scale="0.15000 0.17500 0.07500"/>
            </geometry>
        </collision>
        <visual name="arm_1">
            <origin xyz="0.72000 0.00000 0.01000" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.002.dae" scale="0.15000 0.17500 0.07500"/>
            </geometry>
            <material name="arm_grey">
                <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        </link>

        <joint name="arm_2_link_joint" type="revolute">
        <parent link="arm_1_link"/>
        <child link="arm_2_link"/>
        <origin xyz="1.46 0 0.15" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.356" upper="2.356" effort="50" velocity="2"/>
        </joint>

        <link name="arm_2_link">
        <!-- <collision name="arm_2_collision">
            <origin xyz="0.76000 0.00000 0.01000" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.004.dae" scale="0.15000 0.17500 0.07500"/>
            </geometry>
        </collision> -->
        <visual name="arm_2">
            <origin xyz="0.76000 0.00000 0.01000" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.004.dae" scale="0.15000 0.17500 0.07500"/>
            </geometry>
            <material name="arm_grey">
                <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        </link>

        <joint name="arm_3_link_joint" type="revolute">
        <parent link="arm_2_link"/>
        <child link="arm_3_link"/>
        <origin xyz="1.46 0 -0.11" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="50" velocity="2"/>
        </joint>

        <link name="arm_3_link">
        <collision name="arm_3_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.001.dae" scale="0.15000 0.15000 0.35000"/>
            </geometry>
        </collision>
        <visual name="arm_3">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <box size="0.30000 0.30000 0.70000"/>
            </geometry>
            <material name="arm_grey">
                <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="3.51000"/>
            <inertia ixx="0.16965" ixy="0.00000" ixz="0.00000"
                    iyy="0.16965" iyz="0.00000" izz="0.05265"/>
        </inertial>
        </link>

        <joint name="arm_4_link_joint" type="prismatic">
        <parent link="arm_3_link"/>
        <child link="arm_4_link"/>
        <origin xyz="0 0 -1.05" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.38" upper="1.5" effort="50" velocity="1.0"/>
        </joint>

        <link name="arm_4_link">
        <collision name="arm_4_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cylinder.003.dae" scale="0.07500 0.07500 0.75000"/>
            </geometry>
        </collision>
        <visual name="arm_4">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <cylinder radius="0.07500" length="1.50000"/>
            </geometry>
            <material name="arm_grey">
                <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.00000"/>
            <inertia ixx="0.18891" ixy="0.00000" ixz="0.00000"
                    iyy="0.18891" iyz="0.00000" izz="0.00281"/>
        </inertial>
        </link>

        <joint name="base_endEffector_link_joint" type="fixed">
        <parent link="arm_4_link"/>
        <child link="base_endEffector_link"/>
        <origin xyz="0 0 -0.73" rpy="0 0 0"/>
        </joint>

        <link name="base_endEffector_link">
        <collision name="base_endEffector_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <mesh filename="${mesh_dir}/Cube.001.dae" scale="0.20000 0.40000 0.05000"/>
            </geometry>
        </collision>
        <visual name="base_endEffector">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <box size="0.40000 0.80000 0.10000"/>
            </geometry>
            <material name="arm_grey">
                <color rgba="0.65 0.65 0.65 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.00000"/>
            <inertia ixx="0.05417" ixy="0.00000" ixz="0.00000"
                    iyy="0.01417" iyz="0.00000" izz="0.06667"/>
        </inertial>
        </link>

    </xacro:macro>

</robot>